# Host path to the secrets directory (contains .env and data/).
# Used by Docker Compose for variable substitution — not passed into the container.
# Required when running docker compose; set this in the repo-root .env file.
# JOBFIT_HOME=/home/youruser/Projects/secrets/jobfit

# Dashboard output directory. Default: ./dashboards (relative to CWD).
# Docker Compose sets JOBFIT_REPORTS_DIR=/app/dashboards inside the container.
# JOBFIT_REPORTS_DIR=./dashboards

# Personal data root. Default: ./data (relative to CWD).
# Docker Compose sets JOBFIT_DATA_DIR=/secrets/jobfit/data inside the container.
# JOBFIT_DATA_DIR=./data

# Job listings data (ATS caches, Bundesagentur raw, seen-files).
# Default: $JOBFIT_DATA_DIR/jobs — override to point at a shared volume.
# JOBFIT_JOBS_DATA_DIR=/mnt/shared/jobfit/jobs

# User data (CV source, photos, scoring.yaml, generated PDFs).
# Default: $JOBFIT_DATA_DIR/user — override to isolate personal artifacts.
# JOBFIT_USER_DATA_DIR=~/Projects/secrets/jobfit/data/user

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Scenario 1: Anthropic (default)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your_anthropic_key_here
# CV_MODEL=claude-haiku-4-5

# Scenario 2: Google Gemini (cheapest paid, direct)
# LLM_PROVIDER=openai-compat
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your-google-ai-key
# CV_MODEL=gemini-2.5-flash

# Scenario 3: OpenRouter (free models / unified access)
# LLM_PROVIDER=openai-compat
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-your-openrouter-key
# CV_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Scenario 4: Ollama (local)
# LLM_PROVIDER=openai-compat
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# CV_MODEL=llama3.2
# ─────────────────────────────────────────────────────────────────────────────

# Scenario 5: CV extract + generate + Anschreiben on Anthropic, everything else on Gemini
# LLM_PROVIDER=openai-compat
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your-google-ai-key
# LLM_MODEL=gemini-2.5-flash
#
# CV_PROVIDER=anthropic
# CV_API_KEY=your-anthropic-key
# CV_MODEL=claude-sonnet-4-6
# ─────────────────────────────────────────────────────────────────────────────

# ── Fallback LLM (optional) ───────────────────────────────────────────────────
# Used automatically when primary LLM returns any error (429, 400, timeout, etc.)
# LLM_FALLBACK_PROVIDER=anthropic
# LLM_FALLBACK_API_KEY=sk-ant-your-key        # optional, falls back to LLM_API_KEY
# LLM_FALLBACK_MODEL=claude-haiku-4-5         # optional, uses provider default
# LLM_FALLBACK_BASE_URL=                      # required only if FALLBACK_PROVIDER=openai-compat
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (Docker Compose — used by db service and DATABASE_URL in compose)
# POSTGRES_DB=jobfit
# POSTGRES_USER=jobfit
# POSTGRES_PASSWORD=changeme

# Local dev only (docker-compose overrides DATABASE_URL host to db:5432)
# DATABASE_URL=postgresql://jobfit:jobfit@localhost:5432/jobfit

# CV anonymization before LLM calls (extract + generate). Set to 0 to send raw CV text.
# CV_ANONYMIZE_LLM=1

# Per-command overrides (optional — takes priority over LLM_MODEL)
# CV_MODEL=claude-sonnet-4-6
# CV_PROVIDER=anthropic          # CV extract + generate + Anschreiben; classify/brands use LLM_PROVIDER
# CV_API_KEY=your-anthropic-key  # optional if same as LLM_API_KEY
# CV_BASE_URL=                   # only for CV_PROVIDER=openai-compat
# CV_EXTRACT_MODEL=claude-haiku-4-5
# CLASSIFY_MODEL=claude-haiku-4-5
# BRANDS_MODEL=claude-haiku-4-5

# Per-command fallback model overrides (optional — takes priority over LLM_FALLBACK_MODEL)
# CV_FALLBACK_PROVIDER=openai-compat
# CV_FALLBACK_API_KEY=your-google-ai-key
# CV_FALLBACK_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CLASSIFY_FALLBACK_MODEL=claude-haiku-4-5
# BRANDS_FALLBACK_MODEL=claude-haiku-4-5
# CV_FALLBACK_MODEL=claude-sonnet-4-6
# CV_EXTRACT_FALLBACK_MODEL=claude-haiku-4-5

# Gemini 2.5+ thinking tokens count against max_tokens. Use "none" for structured JSON tasks.
# Auto-set to "none" for gemini-2.5/3 models; override here if needed.
# LLM_REASONING_EFFORT=none

# Default model for all commands (classify, brands, cv extract, cv generate)
# LLM_MODEL=claude-haiku-4-5

# ── Ever Jobs sidecar ─────────────────────────────────────────────────────────
# URL of the self-hosted ever-jobs service (default: http://localhost:3001)
# In Docker Compose this is set automatically to http://everjobs:3001
# EVERJOBS_URL=http://localhost:3001

# Adzuna API credentials (free tier: https://developer.adzuna.com)
# Required for the "adzuna" source in ever-jobs
# ADZUNA_APP_ID=your_app_id
# ADZUNA_APP_KEY=your_app_key
